# Kavach 2.0 Environment Configuration
# Copy this file to .env and fill in your values

# LLM API (choose one — Gemini is FREE)
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_key_here

# WhatsApp Business Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=your_token_here
WHATSAPP_PHONE_NUMBER_ID=your_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# Twilio SMS (fallback)
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# BHASHINI API (multilingual translation)
BHASHINI_API_KEY=your_key_here
BHASHINI_USER_ID=your_user_id_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./kavach.db

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
